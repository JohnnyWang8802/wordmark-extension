{
  "manifest_version": 3,
  "name": "WordMark — 每日生词本",
  "version": "1.0.0",
  "description": "Capture, organize, and memorize vocabulary while reading web articles.",
  "permissions": [
    "storage",
    "alarms",
    "notifications",
    "scripting"
  ],
  "host_permissions": [
    "https://api.dictionaryapi.dev/*",
    "https://api.mymemory.translated.net/*",
    "http://*/*",
    "https://*/*",
    "https://translate.google.com/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://*/*", "http://*/*"],
      "js": ["content.js"],
      "css": ["content.css"]
    }
  ],
  "action": {
    "default_popup": "src/popup/index.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "side_panel": {
    "default_path": "src/popup/index.html"
  }
}
